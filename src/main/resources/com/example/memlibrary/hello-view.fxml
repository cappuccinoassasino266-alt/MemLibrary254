<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.memlibrary.HelloController"

            style="
                -fx-font-family: 'Segoe UI';
                -fx-background-color:
                    linear-gradient(to bottom, #edf4ff 0%, #d4e3f7 40%, #bdd0eb 100%);
            ">

    <top>

        <VBox>

            <HBox alignment="CENTER_LEFT"
                  prefHeight="54"

                  style="
                    -fx-background-color:
                        linear-gradient(to bottom, #fcfeff 0%, #dfeafb 50%, #bfd3f0 100%);
                    -fx-border-color: rgba(90,120,160,0.5);
                    -fx-border-width: 0 0 1 0;
                  ">

                <padding>
                    <Insets top="10" right="18" bottom="10" left="18"/>
                </padding>

                <Label text="🎵 Бібліотека мемів"
                       style="
                            -fx-font-size: 25px;
                            -fx-font-weight: bold;
                            -fx-text-fill: #17365d;
                       "/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="Windows Longhorn Style"
                       style="
                            -fx-font-size: 12px;
                            -fx-text-fill: #4c6787;
                       "/>

            </HBox>

            <Pane prefHeight="2"

                  style="
                    -fx-background-color:
                        linear-gradient(to right,
                        rgba(255,255,255,0.9),
                        rgba(120,160,220,0.4),
                        rgba(255,255,255,0.9));
                  "/>

        </VBox>

    </top>

    <left>

        <VBox spacing="12"
              prefWidth="190"

              style="
                -fx-background-color:
                    linear-gradient(to bottom, rgba(255,255,255,0.75) 0%, rgba(210,225,245,0.92) 100%);
                -fx-border-color: rgba(120,145,180,0.5);
                -fx-border-width: 0 1 0 0;
              ">

            <padding>
                <Insets top="18" right="12" bottom="18" left="12"/>
            </padding>

            <VBox spacing="4">

                <Label text="Меми"
                       style="
                            -fx-font-size: 21px;
                            -fx-font-weight: bold;
                            -fx-text-fill: #204060;
                       "/>

                <Label text="Обери мем зі списку"
                       style="
                            -fx-font-size: 11px;
                            -fx-text-fill: #5d7896;
                       "/>

            </VBox>

            <Pane prefHeight="1"

                  style="
                    -fx-background-color:
                        linear-gradient(to right,
                        transparent,
                        rgba(130,160,200,0.7),
                        transparent);
                  "/>

            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER"

                        style="
                            -fx-background: transparent;
                            -fx-background-color: transparent;
                            -fx-padding: 0;
                        ">

                <content>

                    <VBox fx:id="iconContainer"
                          alignment="TOP_CENTER"
                          spacing="12"/>

                </content>

            </ScrollPane>

        </VBox>

    </left>

    <center>

        <VBox alignment="TOP_CENTER"
              spacing="18"

              style="
                -fx-background-color:
                    linear-gradient(to bottom, rgba(255,255,255,0.4), rgba(220,232,248,0.7));
              ">

            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>

            <StackPane

                    style="
                        -fx-background-color:
                            linear-gradient(to bottom,
                            rgba(255,255,255,0.98) 0%,
                            rgba(233,241,252,0.98) 100%);
                        -fx-background-radius: 22;
                        -fx-border-radius: 22;
                        -fx-border-color: rgba(120,150,190,0.8);
                        -fx-border-width: 1.7;
                        -fx-effect:
                            dropshadow(gaussian, rgba(0,0,0,0.18), 22, 0.18, 0, 6);
                    ">

                <padding>
                    <Insets top="18" right="18" bottom="18" left="18"/>
                </padding>

                <VBox spacing="10" alignment="CENTER">

                    <ImageView fx:id="mainImageView"
                               fitHeight="400"
                               fitWidth="650"
                               preserveRatio="true"/>

                    <Pane prefHeight="1"
                          maxWidth="620"

                          style="
                            -fx-background-color:
                                linear-gradient(to right,
                                transparent,
                                rgba(140,170,210,0.6),
                                transparent);
                          "/>

                    <Label text="Популярний мем"
                           style="
                                -fx-font-size: 11px;
                                -fx-text-fill: #6c86a5;
                           "/>

                </VBox>

            </StackPane>

            <TextArea fx:id="descriptionArea"
                      editable="false"
                      wrapText="true"
                      prefHeight="145"
                      prefWidth="670"

                      style="
                        -fx-control-inner-background:
                            linear-gradient(to bottom,
                            rgba(255,255,255,0.98) 0%,
                            rgba(238,245,253,1) 100%);
                        -fx-background-radius: 16;
                        -fx-border-radius: 16;
                        -fx-border-color: rgba(125,150,185,0.75);
                        -fx-border-width: 1.5;
                        -fx-font-size: 14px;
                        -fx-text-fill: #22364d;
                        -fx-padding: 12;
                    "/>

            <Button fx:id="playButton"
                    onAction="#playAudio"
                    text="▶ Програти аудіо"

                    style="
                        -fx-background-color:
                            linear-gradient(to bottom,
                            #ffffff 0%,
                            #dce9fb 45%,
                            #aec6ea 100%);
                        -fx-background-radius: 16;
                        -fx-border-radius: 16;
                        -fx-border-color: #6d8eb5;
                        -fx-border-width: 1.3;
                        -fx-font-size: 15px;
                        -fx-font-weight: bold;
                        -fx-text-fill: #17365d;
                        -fx-padding: 11 28 11 28;
                    "/>

        </VBox>

    </center>

</BorderPane>